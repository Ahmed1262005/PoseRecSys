# ==============================================================================
# OutfitTransformer - Environment Configuration
# ==============================================================================
# Copy to .env and fill in your values:  cp .env.example .env

# === REQUIRED ===

# Supabase (database + pgvector + auth + storage)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-key
SUPABASE_JWT_SECRET=your-jwt-secret

# Algolia (search)
ALGOLIA_APP_ID=your-algolia-app-id
ALGOLIA_SEARCH_KEY=your-algolia-search-key
ALGOLIA_INDEX_NAME=products

# === OPTIONAL ===

# OpenAI (query planner + stylist judge)
OPENAI_API_KEY=
QUERY_PLANNER_MODEL=gpt-4.1-mini
QUERY_PLANNER_ENABLED=true
LLM_JUDGE_ENABLED=false
USE_LLM_JUDGE=false

# Pinterest integration
PINTEREST_APP_ID=
PINTEREST_APP_SECRET=
PINTEREST_REDIRECT_URI=https://usepose.com/api/integrations/pinterest/callback
PINTEREST_OAUTH_STATE_SECRET=

# Weather (context-aware recommendations)
OPENWEATHER_API_KEY=

# Redis (session state persistence)
REDIS_URL=redis://redis:6379/0
REDIS_ENABLED=true

# === SERVER ===

HOST=0.0.0.0
PORT=8000
WORKERS=2
ENVIRONMENT=production
DEBUG=false

# CORS (comma-separated origins)
CORS_ORIGINS=https://usepose.com,https://www.usepose.com,https://api.usepose.com

# === PATHS ===

BASE_DIR=/app
SASREC_MODEL_PATH=/app/models/SASRec-Dec-11-2025_18-20-35.pth
RECBOLE_DATA_PATH=/app/data/recbole

# === DATADOG (set in docker-compose.yml, override here if needed) ===

# DD_SERVICE=outfit-api
# DD_ENV=production
# DD_VERSION=3.0.0
# DD_AGENT_HOST=host.docker.internal
# DD_TRACE_SAMPLE_RATE=1

# === WRITE KEYS (indexing scripts only, not needed at runtime) ===

# ALGOLIA_WRITE_KEY=your-algolia-write-key
# GOOGLE_API_KEY=your-gemini-api-key
