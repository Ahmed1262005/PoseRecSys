# Git
.git/
.github/
.gitignore

# Virtual environments
.venv/
venv/

# Environment (secrets)
.env
.env.*
!.env.example

# Python cache
__pycache__/
*.pyc
*.pyo
*.egg-info/

# Data and models (mounted as volumes, not baked in)
data/
models/
*.pkl
*.npy
*.pth
*.bin

# Scripts (dev/test tools, not needed at runtime)
scripts/

# Tests
tests/
.pytest_cache/
.coverage
htmlcov/

# Documentation
docs/
sql/
*.md
!requirements*.txt

# Generated reports
*.html

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# SSL certs (mounted as volume, not baked in)
ssl/
*.pem

# Gradio / Claude / OpenCode
.gradio/
.claude/
.opencode/

# Logs
*.log
logs/
